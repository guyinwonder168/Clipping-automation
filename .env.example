# ─── Required API Keys ──────────────────────────────────────────────────────
# These must be set to run the pipeline or the application will fail with
# a clear ValueError at startup.
OPENROUTER_API_KEY=sk-or-v1-
ELEVENLABS_API_KEY=
PEXELS_API_KEY=
SCRAPECREATORS_API_KEY=
FIRECRAWL_API_KEY=

# ─── Dashboard (required for web UI) ───────────────────────────────────────
# If DASHBOARD_USERNAME or DASHBOARD_PASSWORD is unset, all auth attempts are
# rejected (fails closed). If DASHBOARD_SECRET_KEY is unset, all state-changing
# requests (POST, PUT, PATCH, DELETE) return 403.
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=changeme
DASHBOARD_SECRET_KEY=
# ⚠  IMPORTANT: If a value starts with '#', wrap it in double quotes:
#     DASHBOARD_PASSWORD="#my-secret"
#     DASHBOARD_SECRET_KEY="#abc123"
#   Unquoted values starting with '#' may be treated as comments by some
#   parsers (shell source, docker-compose, etc.). python-dotenv handles it
#   correctly, but quoting is the safe cross-tool convention.

# ─── Per-Agent LLM Models (optional — defaults to mimo-v2-flash) ─────────────
# SAFETY_MODEL=mimo-v2-flash
# RESEARCHER_MODEL=mimo-v2-flash
# SCRIPTWRITER_MODEL=mimo-v2-flash
# REVIEWER_MODEL=mimo-v2-flash

# ─── Logging ─────────────────────────────────────────────────────────────────
# DEBUG for verbose API traces, INFO for normal output, WARNING/ERROR for prod
LOG_LEVEL=INFO

# ─── Paths (optional — defaults shown) ───────────────────────────────────────
# These map to AppSettings fields and can be overridden via environment or .env.
DB_PATH=data/clipper.db
ASSETS_CACHE=assets/cache
OUTPUT_DIR=outputs
